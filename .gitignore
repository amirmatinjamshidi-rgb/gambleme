# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.local.example

# vercel
.vercel

# next.js bundle analyzer
.analyze/
.next/analyze/

# three.js / react-three-fiber local caches
.three/
.r3f-cache/

# typescript
*.tsbuildinfo
next-env.d.ts
